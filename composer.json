{
    "name": "laminas/laminas-navigation-view",
    "description": "Integrates laminas-navigation with laminas-view",
    "license": "BSD-3-Clause",
    "keywords": [
        "laminas",
        "navigation",
        "view"
    ],
    "homepage": "https://laminas.dev",
    "support": {
        "docs": "https://docs.laminas.dev/laminas-navigation-view/",
        "issues": "https://github.com/laminas/laminas-navigation-view/issues",
        "source": "https://github.com/laminas/laminas-navigation-view",
        "rss": "https://github.com/laminas/laminas-navigation-view/releases.atom",
        "chat": "https://laminas.dev/chat",
        "forum": "https://discourse.laminas.dev"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.1.99"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "laminas": {
            "component": "Laminas\\Navigation\\View",
            "config-provider": "Laminas\\Navigation\\View\\ConfigProvider"
        }
    },
    "require": {
        "php": "~8.1.0 || ~8.2.0 || ~8.3.0 || ~8.4.0",
        "ext-dom": "*",
        "laminas/laminas-eventmanager": "^3.14",
        "laminas/laminas-navigation": "^2.20.0",
        "laminas/laminas-permissions-acl": "^2.17.0",
        "laminas/laminas-servicemanager": "^3.23.0",
        "laminas/laminas-stdlib": "^3.20.0",
        "laminas/laminas-translator": "^1.1",
        "laminas/laminas-uri": "^2.13.0",
        "laminas/laminas-validator": "^2.64.2",
        "laminas/laminas-view": "^2.36.0",
        "psr/container": "^1.1.2 || ^2.0"
    },
    "require-dev": {
        "laminas/laminas-coding-standard": "~3.1.0",
        "laminas/laminas-i18n": "^2.30",
        "laminas/laminas-mvc": "^3.8",
        "laminas/laminas-router": "^3.14",
        "phpunit/phpunit": "^10.5.45",
        "psalm/plugin-phpunit": "^0.19.5",
        "vimeo/psalm": "^6.10.1"
    },
    "autoload": {
        "psr-4": {
            "Laminas\\Navigation\\View\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaminasTest\\Navigation\\View\\": "test/"
        }
    },
    "scripts": {
        "check": [
            "@cs-check",
            "@test"
        ],
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "test": "phpunit --colors=always",
        "test-coverage": "phpunit --colors=always --coverage-clover clover.xml",
        "static-analysis": "psalm --shepherd --stats"
    }
}
